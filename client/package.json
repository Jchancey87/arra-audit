{
  "name": "arra-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "axios": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "wavesurfer.js": "^7.12.8"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lighthouse": "npm run build && npm run preview & LIGHTHOUSE_PREVIEW_PID=$! ; sleep 3 && node ../scripts/lighthouse.mjs --url http://localhost:4173 ; kill $LIGHTHOUSE_PREVIEW_PID 2>/dev/null || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "adm-zip": "^0.5.17",
    "jsdom": "^25.0.1",
    "lighthouse": "^13.4.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
